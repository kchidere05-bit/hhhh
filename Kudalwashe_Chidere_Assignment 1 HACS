        "import matplotlib.pyplot as plt\n",
        "import yfinance as yf\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "\n",
        "# Re-define df for robustness in case previous cell was not run\n",
        "ticker = \"AAPL\"\n",
        "start_date = \"2018-01-01\"\n",
        "end_date = \"2025-12-31\"\n",
        "df = yf.download(ticker, start=start_date, end=end_date, auto_adjust=False, progress=False)\n",
        "\n",
        "# Re-define df_clean for robustness in case previous cell was not run\n",
        "# This code is copied from cell oF3fa3aXut2z\n",
        "if 'Adj Close' in df.columns:\n",
        "    price_col = 'Adj Close'\n",
        "elif 'Close' in df.columns:\n",
        "    price_col = 'Close'\n",
        "\n",
        "df_clean = pd.DataFrame()\n",
        "df_clean['Price'] = df[price_col]\n",
        "df_clean['Return'] = df_clean['Price'].pct_change() * 100\n",
        "df_clean = df_clean.dropna()\n",
        "\n",
        "fig, axes = plt.subplots(2, 2, figsize=(14, 10))\n",
        "\n",
        "returns = df_clean['Return'] # Define returns here for use in this cell\n",
        "\n",
        "# Calculate quartiles and IQR for outlier definition\n",
        "Q1 = returns.quantile(0.25)\n",
        "Q3 = returns.quantile(0.75)\n",
        "IQR = Q3 - Q1\n",
        "\n",
        "# Define outlier thresholds based on IQR\n",
        "# Moderate outliers: beyond 1.5*IQR but within 3*IQR\n",
        "moderate_lower = returns[(returns < Q1 - 1.5 * IQR) & (returns >= Q1 - 3 * IQR)]\n",
        "moderate_upper = returns[(returns > Q3 + 1.5 * IQR) & (returns <= Q3 + 3 * IQR)]\n",
        "moderate_outliers = pd.concat([moderate_lower, moderate_upper])\n",
        "\n",
        "# Extreme outliers: beyond 3*IQR\n",
        "extreme_lower = returns[returns < Q1 - 3 * IQR]\n",
        "extreme_upper = returns[returns > Q3 + 3 * IQR]\n",
        "extreme_outliers = pd.concat([extreme_lower, extreme_upper])\n",
        "\n",
        "# Price series\n",
        "axes[0, 0].plot(df_clean.index, df_clean['Price'], color='darkblue', linewidth=1)\n",
        "axes[0, 0].set_title('AAPL Stock Price (2018-2025)', fontsize=12)\n",
        "axes[0, 0].set_ylabel('Price (USD)')\n",
        "axes[0, 0].grid(True, alpha=0.3)\n",
        "\n",
        "# Returns series with highlighted outliers\n",
        "axes[0, 1].plot(df_clean.index, returns, color='darkgray', alpha=0.5, linewidth=0.5, label='All Returns')\n",
        "axes[0, 1].axhline(y=0, color='black', linestyle='-', linewidth=0.5)\n",
        "\n",
        "# Highlight moderate outliers\n",
        "axes[0, 1].scatter(moderate_outliers.index, moderate_outliers, color='teal', s=30, zorder=5, label='Moderate Outliers (1.5-3 IQR)')\n",
        "\n",
        "# Highlight extreme outliers\n",
        "axes[0, 1].scatter(extreme_outliers.index, extreme_outliers, color='orange', s=50, zorder=6, label='Extreme Outliers (>3 IQR)')\n",
        "\n",
        "axes[0, 1].set_title('AAPL Daily Returns (%) with Outliers', fontsize=12)\n",
        "axes[0, 1].set_ylabel('Return (%)')\n",
        "axes[0, 1].grid(True, alpha=0.3)\n",
        "axes[0, 1].legend()\n",
